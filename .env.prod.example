APP_NAME=Mintel
ENVIRONMENT=production
SECRET_KEY=change-this-to-a-long-random-production-secret
BOOTSTRAP_ADMIN_EMAIL=admin@mintel.local
BOOTSTRAP_ADMIN_PASSWORD=change-this-before-first-start
BOOTSTRAP_ADMIN_NAME=Mintel Admin

POSTGRES_DB=mintel
POSTGRES_USER=mintel
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://mintel:change-this-database-password@mintel_postgres:5432/mintel
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=50
DATABASE_POOL_TIMEOUT=10

MAAS_BASE_URL=https://midhtech.in
MAAS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ALLOWED_HOSTS=mintel.midhtech.in,localhost,127.0.0.1
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
BEHIND_PROXY=true
TZ=America/Chicago

MINTEL_PORT=8009
